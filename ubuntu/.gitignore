# Ignore downloaded packages (too large for git)
offline/packages/

# Ignore checksums (generated)
offline/manifests/checksums.sha256
offline/manifests/manifest.json

# Ignore Docker workspace
docker/workspace/*
!docker/workspace/.gitkeep

# Ignore vim runtime files
*.swp
*.swo
*~

# Ignore lazy-lock
config/lazy-lock.json
